# --- Server ---
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000

# --- Database ---
DATABASE_URL=postgres://edualerta:edualerta@localhost:5432/edualerta

# --- Redis (sessions, rate limit, pub-sub) ---
REDIS_URL=redis://localhost:6379

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-too-and-make-it-different
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
BCRYPT_ROUNDS=10

# --- 3rd party ---
GOOGLE_MAPS_API_KEY=your-google-maps-key

# --- Logger ---
LOG_LEVEL=info
